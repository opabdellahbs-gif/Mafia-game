body {
    background: linear-gradient(135deg, #0f0f0f, #1a1a1a);
    color: white;
    font-family: Arial;
    text-align: center;
}

h1 {
    color: crimson;
}

.box {
    margin: 20px;
}

input {
    padding: 10px;
    margin: 5px;
    border-radius: 8px;
    border: none;
}

button {
    padding: 10px 15px;
    margin: 5px;
    background: crimson;
    border: none;
    border-radius: 10px;
    color: white;
    cursor: pointer;
}

button:hover {
    background: darkred;
}

#players div {
    margin: 5px auto;
    padding: 8px;
    width: 200px;
    border: 1px solid white;
    border-radius: 10px;
    cursor: pointer;
}

#players div:hover {
    background: rgba(255,255,255,0.1);
}

#chat {
    height: 150px;
    overflow-y: auto;
    border: 1px solid white;
    margin: 10px;
    padding: 10px;
}
